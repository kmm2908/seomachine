              {
                "id": "3dc466c",
                "elType": "widget",
                "settings": {
                  "html": "<!-- Driving Directions Widget — Serendipity Massage Therapy & Wellness -->\n<!-- Generated by generate_directions_snippet.py | Using address as destination — add \"place_id\" to config.json for more accurate routing. -->\n<div class=\"seo-directions\" style=\"margin:1.5em 0;\">\n  <p style=\"margin-bottom:0.75em;\">Get driving directions to Serendipity Massage Therapy & Wellness:</p>\n  <div style=\"display:flex;gap:0.5em;flex-wrap:wrap;align-items:stretch;\">\n    <input\n      type=\"text\"\n      id=\"seo-dir-origin-sdy\"\n      placeholder=\"Enter your postcode or address\"\n      style=\"flex:1 1 220px;padding:0.55em 0.75em;font-size:1rem;border:1px solid #ccc;border-radius:4px;\"\n      onkeydown=\"if(event.key==='Enter')seoGetDirections_sdy()\"\n    />\n    <button\n      onclick=\"seoGetDirections_sdy()\"\n      style=\"padding:0.55em 1.25em;font-size:1rem;background:#2c6e49;color:#fff;border:none;border-radius:4px;cursor:pointer;white-space:nowrap;\"\n    >Get Directions</button>\n  </div>\n  <p style=\"margin-top:0.6em;font-size:0.85em; font-weight: bold;\"0>Serendipity Massage Therapy & Wellness &mdash; Floor 1, Suite 50, Central Chambers, 93 Hope Street, Glasgow G2 6LD</p>\n</div>\n<script>\nfunction seoGetDirections_sdy() {\n  var origin = document.getElementById('seo-dir-origin-sdy').value.trim();\n  if (!origin) {\n    alert('Please enter your starting location.');\n    return;\n  }\n  var url = 'https://www.google.com/maps/dir/?api=1'\n    + '&origin=' + encodeURIComponent(origin)\n    + '&destination=Floor+1%2C+Suite+50%2C+Central+Chambers%2C+93+Hope+Street%2C+Glasgow+G2+6LD'\n    + '&travelmode=driving';\n  window.open(url, '_blank');\n}\n</script>\n<!-- End Driving Directions Widget -->"
                },
